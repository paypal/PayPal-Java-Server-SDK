#!/usr/bin/env groovy
// This file manages the CI jobs for a Nodejs Application
// The latest documentation can always be found in https://go/epx-nodejs-pipeline

// noinspection GroovyUnusedAssignment
@Library('mavenPipeline')_ // always use the latest

nodejsGitflowReleasePipeline {
  mainBranch = 'main'
  disableLintStage = true
  disableTestStages = true
  disableSonarQubeStage = true
}
